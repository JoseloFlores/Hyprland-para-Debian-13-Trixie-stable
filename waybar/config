{
    "layer": "top",
    "position": "top",
    "height": 30,
    "spacing": 2,
    "output": "eDP-1",
    "modules-left": ["hyprland/workspaces", "hyprland/window"],
    "modules-center": [],
    "modules-right": ["custom/updates", "pulseaudio", "network", "bluetooth", "cpu", "memory", "battery", "clock", "tray", "group/power"],

    "group/power": {
        "orientation": "inherit",
        "drawer": {
            "transition-duration": 500,
            "children-class": "not-power",
            "transition-left-to-right": false
        },
        "modules": [
            "custom/power", // Este es el icono que siempre se ve
            "custom/quit",
            "custom/lock",
            "custom/reboot"
        ]
    },
    "custom/power": {
        "format": "⏻",
        "tooltip": false,
        "on-click": "~/.config/hypr/confirm_power.sh \"¿Apagar el sistema?\" \"shutdown now\""
    },
    "custom/quit": {
        "format": "󰗼",
        "tooltip": false,
        "on-click": "~/.config/hypr/confirm_power.sh \"¿Cerrar sesión?\" \"hyprctl dispatch exit\""
    },
    "custom/lock": {
        "format": "󰌾",
        "tooltip": false,
        "on-click": "loginctl lock-session"
    },
    "custom/reboot": {
        "format": "󰜉",
        "tooltip": false,
        "on-click": "~/.config/hypr/confirm_power.sh \"¿Reiniciar el sistema?\" \"reboot\""
    },

    "custom/updates": {
        "format": "󰏖 {}",
        "interval": 3600,
        "exec": "~/.config/hypr/check_updates.sh",
        "on-click": "gnome-terminal -- sh -c 'if command -v nala > /dev/null; then sudo nala upgrade; elif command -v apt > /dev/null; then sudo apt update && sudo apt upgrade; elif command -v pacman > /dev/null; then sudo pacman -Syu; elif command -v dnf > /dev/null; then sudo dnf update; fi'",
        "tooltip": false
    },

    "hyprland/workspaces": {
        "format": "{name}",
        "on-click": "activate",
        "format-icons": {
            "active": "",
            "default": ""
        }
    },

    "hyprland/window": {
        "format": "{}",
        "max-length": 50,
        "separate-outputs": true
    },

    "tray": {
        "spacing": 10
    },

    "clock": {
        "timezone": "America/Argentina/Buenos_Aires",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format": " {:%H:%M   %d/%m}",
        "format-alt": " {:%H:%M:%S}"
    },

    "cpu": {
        "format": " {usage}%",
        "tooltip": false
    },

    "memory": {
        "format": " {}%"
    },

    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": " {capacity}%",
        "format-plugged": " {capacity}%",
        "format-icons": ["", "", "", "", ""]
    },

    "network": {
        "format-wifi": " {essid}",
        "format-ethernet": " {ifname}",
        "tooltip-format": " {ifname} via {gwaddr}",
        "format-linked": " {ifname} (No IP)",
        "format-disconnected": "⚠ Disconnected",
        "format-alt": "{ifname}: {ipaddr}/{cidr}",
        "on-click": "adwaita-network"
    },

    "bluetooth": {
        "format": " {status}",
        "format-connected": " {device_alias}",
        "format-connected-battery": " {device_alias} {device_battery_percentage}%",
        "on-click": "blueman-manager"
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "{icon} {volume}% {format_source}",
        "format-bluetooth-muted": " {icon} {format_source}",
        "format-muted": " {format_source}",
        "format-icons": {
            "headphone": "",
            "hands-free": "",
            "headset": "",
            "phone": "",
            "portable": "",
            "car": "",
            "default": ["", "", ""]
        },
        "on-click": "pavucontrol"
    }
}
