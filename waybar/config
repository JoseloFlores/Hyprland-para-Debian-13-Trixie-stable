{
    "layer": "top",
    "position": "top",
    "height": 30,
    "spacing": 0,
    "output": "eDP-1",
    "modules-left": ["hyprland/workspaces", "hyprland/window"],
    "modules-center": ["mpris"],
    "modules-right": ["group/quicksettings", "clock", "custom/updates", "backlight", "tray", "group/power"],

    "backlight": {
        "device": "intel_backlight",
        "format": "{icon} {percent}%",
        "format-icons": ["оЋЌ", "оЏ“", "оЏ‘", "оЏЏ", "оЏЋ", "оЏЌ", "оЏЉ", "оЏ€", "оЋ›"],
        "on-scroll-up": "brightnessctl set 1%+",
        "on-scroll-down": "brightnessctl set 1%-",
        "min-length": 6
    },

    "group/quicksettings": {
        "orientation": "inherit",
        "modules": [
            "pulseaudio",
            "network",
            "bluetooth",
            "battery"
        ]
    },

    "mpris": {
        "format": "{player_icon} {title} - {artist} [{position}/{length}]",
        "format-paused": "{status_icon} <i>{title} - {artist}</i>",
        "player-icons": {
            "default": "в–¶",
            "spotify": "п†ј",
            "firefox": "п‰©"
        },
        "status-icons": {
            "paused": "вЏё"
        },
        "max-length": 40,
        "on-click": "playerctl play-pause",
        "on-click-right": "playerctl next",
        "on-click-middle": "playerctl previous",
        "on-scroll-up": "playerctl next",
        "on-scroll-down": "playerctl previous"
    },

    "group/power": {
        "orientation": "inherit",
        "drawer": {
            "transition-duration": 500,
            "children-class": "not-power",
            "transition-left-to-right": false
        },
        "modules": [
            "custom/power", 
            "custom/lock",
            "custom/reboot",
            "custom/quit"
        ]
    },
    "custom/power": {
        "format": "вЏ»",
        "tooltip": false,
        "on-click": "~/.config/hypr/confirm_power.sh \"ВїApagar el sistema?\" \"shutdown now\""
    },
    "custom/quit": {
        "format": "у°—ј",
        "tooltip": false,
        "on-click": "~/.config/hypr/confirm_power.sh \"ВїCerrar sesiГіn?\" \"hyprctl dispatch exit\""
    },
    "custom/lock": {
        "format": "у°Њѕ",
        "tooltip": false,
        "on-click": "loginctl lock-session"
    },
    "custom/reboot": {
        "format": "у°њ‰",
        "tooltip": false,
        "on-click": "~/.config/hypr/confirm_power.sh \"ВїReiniciar el sistema?\" \"reboot\""
    },

    "custom/updates": {
        "format": "{}",
        "interval": 3600,
        "return-type": "json",
        "exec": "~/.config/hypr/check_updates.sh",
        "on-click": "foot sh -c 'sudo apt update && sudo apt upgrade -y; pkill -SIGRTMIN+8 waybar; echo \"Sistema actualizado. Presiona cualquier tecla para cerrar...\"; read -n 1'",
        "signal": 8,
        "tooltip": false
    },

    "hyprland/workspaces": {
        "format": "{name}",
        "on-click": "activate",
        "format-icons": {
            "active": "п†’",
            "default": "п„Њ"
        }
    },

    "hyprland/window": {
        "format": "{}",
        "max-length": 40,
        "separate-outputs": true
    },

    "tray": {
        "spacing": 10
    },

    "clock": {
        "timezone": "America/Argentina/Buenos_Aires",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format": "пЂ— {:%H:%M  пЃі %d/%m}",
        "format-alt": "пЂ— {:%H:%M}"
    },

    "cpu": {
        "format": "п‹› {usage}%",
        "tooltip": false
    },

    "memory": {
        "format": "пѓ‰ {}%"
    },

    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "п—§ {capacity}%",
        "format-plugged": "п‡¦ {capacity}%",
        "format-icons": ["п‰„", "п‰ѓ", "п‰‚", "п‰Ѓ", "п‰Ђ"]
    },

    "network": {
        "format-wifi": "п‡« {essid}",
        "format-ethernet": "пћ– {ifname}",
        "tooltip-format": "пћ– {ifname} via {gwaddr}",
        "format-linked": "пћ– {ifname} (No IP)",
        "format-disconnected": "вљ  Disconnected",
        "format-alt": "{ifname}: {ipaddr}/{cidr}",
        "on-click": "adwaita-network"
    },

    "bluetooth": {
        "format": "пЉ” {status}",
        "format-connected": "пЉ” {device_alias}",
        "format-connected-battery": "пЉ” {device_alias} {device_battery_percentage}%",
        "on-click": "blueman-manager"
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "{icon}пЉ” {volume}% {format_source}",
        "format-bluetooth-muted": "пљ© {icon}пЉ” {format_source}",
        "format-muted": "пљ© {format_source}",
        "format-icons": {
            "headphone": "пЂҐ",
            "hands-free": "п–ђ",
            "headset": "п–ђ",
            "phone": "п‚•",
            "portable": "п‚•",
            "car": "п†№",
            "default": ["пЂ¦", "пЂ§", "пЂЁ"]
        },
        "on-click": "pavucontrol"
    }
}
